# Google Sign-In (GIS) — Firebase Web client (client_type 3). Refresh via:
#   firebase apps:sdkconfig ANDROID <android-app-id> --project task-zing-m-v-p-e11l44
# then copy other_platform_oauth_client client_type 3 → here and Flutter google_auth.dart.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=211438342424-2q040ab0aqf3ionmc9f8h9n4sjue9ron.apps.googleusercontent.com

# Apple Sign In (web): register return URLs in Apple Developer for Services ID com.taskzing.zingte.webauth:
#   http://localhost:3000/login  http://localhost:3000/signup
#   https://taskzing.com/login   https://taskzing.com/signup
# (Backend /auth/apple/web-config redirect is for mobile; web uses same-origin /login or /signup.)

# Google Maps JavaScript API — same stack as Flutter `google_maps_flutter` + `custom_google_map.dart`.
# Without this key, web maps fall back to Leaflet/OSM with the same Flutter-style overlays.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ChatZing Agent API (voice, vision, posters, jobs). Defaults to Railway production.
NEXT_PUBLIC_CHATZING_API_BASE_URL=https://chatzing-production.up.railway.app
